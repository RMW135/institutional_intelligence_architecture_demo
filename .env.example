# ─── Neo4j Connection ─────────────────────────────────────────────────────────
# Option A — Cloud (Neo4j AuraDB — recommended for sharing a live demo)
NEO4J_URI=neo4j+s://your-instance-id.databases.neo4j.io
NEO4J_USER=your-neo4j-username
NEO4J_PASSWORD=your-neo4j-password

# Option B — Local (Neo4j Desktop)
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your-local-password


# ─── LLM API Keys (both optional — system falls back to rule-based) ────────────
# Extraction priority: Claude → OpenAI → Fallback (rule-based)
# The app works without any LLM key. With a key, Tab 7 comparison is also enabled.

# ANTHROPIC_API_KEY=your-anthropic-api-key

# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4.1-mini
